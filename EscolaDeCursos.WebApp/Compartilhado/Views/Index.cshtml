@{
    Layout = "_Layout";
    ViewBag.Titulo = "Página Inicial";
}

<div class="row g-2">

    <div class="col-lg-7">

        <h1 class="display-5 fw-semibold mb-3">
            Escola de Cursos
        </h1>

        <p class="lead text-secondary mb-4">
            Organize sua vida pessoal e/ou profissional conosco.
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Aluno" asp-action="Listar">
                Alunos
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Curso" asp-action="Listar">
                Cursos
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Turma" asp-action="Listar">
                Turmas
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Matricula" asp-action="Listar">
                Matrículas
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Instrutor" asp-action="Listar">
                Instrutores
            </a>

            <a class="btn btn-primary rounded-pill px-4" asp-controller="Categoria" asp-action="Listar">
                Categorias
            </a>
        </div>

    </div>


    <div class="col-lg-5">

        <div class="card border-primary-subtle shadow-sm">

            <div class="card-body p-4">

                <h3 class="h5 text-primary mb-3">
                    Módulos disponíveis
                </h3>


                <div class="list-group">

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Categoria" asp-action="Listar">
                        Módulo de Categorias
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>


                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Aluno" asp-action="Listar">
                        Módulo de Alunos
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>


                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Curso" asp-action="Listar">
                        Módulo de Cursos
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>


                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Turma" asp-action="Listar">
                        Módulo de Turmas
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>


                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Matricula" asp-action="Listar">
                        Módulo de Matrículas
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>

                    <a class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                       asp-controller="Instrutor" asp-action="Listar">
                        Módulo de Instrutores
                        <span class="badge text-bg-primary rounded-pill">Abrir</span>
                    </a>
                </div>

            </div>

        </div>

    </div>

</div>
