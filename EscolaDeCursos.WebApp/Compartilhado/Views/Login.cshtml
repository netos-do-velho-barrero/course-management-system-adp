@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - EduCore</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <style>
            :root {
                --bg-light: #f8fafc;
                --bg-card: #ffffff;
                --blue-main: #1a56db;
                --blue-hover: #1e429f;
                --blue-dark: #0f1c3f;
                --text-dark: #1e293b;
                --text-muted: #64748b;
                --border-color: #e2e8f0;
            }

            body {
                background-color: var(--bg-light);
                color: var(--text-dark);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                min-height: 100vh;
            }

            .left-banner {
                background: linear-gradient(135deg, #0f1c3f 0%, #081026 100%);
                color: #ffffff;
            }

            .custom-card {
                background-color: var(--bg-card);
                border: 1px solid var(--border-color);
                border-radius: 16px;
                box-shadow: 0 10px 25px rgba(0, 0, 0, 0.04);
            }

            .form-control {
                background-color: #ffffff;
                border: 1px solid #cbd5e1;
                color: var(--text-dark);
                border-radius: 8px;
                padding: 12px;
            }

            .form-control:focus {
                background-color: #ffffff;
                border-color: var(--blue-main);
                color: var(--text-dark);
                box-shadow: 0 0 0 0.25rem rgba(26, 86, 219, 0.15);
            }

            .btn-blue {
                background-color: var(--blue-main);
                color: #ffffff;
                border: none;
                padding: 12px;
                border-radius: 8px;
                font-weight: 600;
                transition: all 0.3s ease;
            }

            .btn-blue:hover {
                background-color: var(--blue-hover);
                color: #ffffff;
                transform: translateY(-2px);
            }

            .feature-icon {
                color: #ffffff;
                background-color: rgba(255, 255, 255, 0.15);
                width: 32px;
                height: 32px;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
                margin-right: 12px;
            }
    </style>
</head>

<body>

    <div class="container-fluid">
        <div class="row min-vh-100">

            <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-between p-5 left-banner">
                <div class="d-flex align-items-center gap-2">
                    <i class="bi bi-mortarboard-fill text-primary fs-3" style="color: #3b82f6 !important;"></i>
                    <span class="fw-bold fs-4 text-white">EduCore</span>
                </div>

                <div class="my-auto">
                    <h1 class="display-4 fw-bold mb-4 text-white">
                        Academic Management <br>System
                    </h1>
                    <p class="fs-5 mb-5" style="color: #94a3b8;">
                        Gerencie cursos, alunos, turmas e matrículas com eficiência e controle total da sua instituição
                        de ensino.
                    </p>

                    <div class="d-flex flex-column gap-3">
                        <div class="d-flex align-items-center">
                            <span class="feature-icon"><i class="bi bi-check-lg text-primary"></i></span>
                            <span class="fw-medium text-white">Gestão de Cursos e Módulos</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <span class="feature-icon"><i class="bi bi-check-lg text-primary"></i></span>
                            <span class="fw-medium text-white">Controle completo de Matrículas</span>
                        </div>
                        <div class="d-flex align-items-center">
                            <span class="feature-icon"><i class="bi bi-check-lg text-primary"></i></span>
                            <span class="fw-medium text-white">Dashboard com indicadores em tempo real</span>
                        </div>
                    </div>
                </div>

                <div style="color: #64748b;" class="small">
                    &copy; 2026 EduCore &mdash; Sistema de Gestão
                </div>
            </div>

            <div class="col-lg-6 d-flex flex-column justify-content-center align-items-center p-4"
                 style="background-color: var(--bg-light);">
                <div class="w-100" style="max-width: 450px;">
                    <div class="card custom-card p-4 p-sm-5">
                        <h2 class="fw-bold mb-1 fs-3 text-dark">Bem-vindo de volta</h2>
                        <p class="text-secondary small mb-4">Entre com suas credenciais para continuar</p>

                        <form asp-controller="Home" asp-action="Dashboard" method="get">
                            <div class="mb-3">
                                <label for="email" class="form-label small fw-semibold text-dark">E-mail</label>
                                <input type="email" class="form-control" id="email" value="admin@educore.com.br"
                                       required>
                            </div>

                            <div class="mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <label for="password"
                                           class="form-label small fw-semibold text-dark mb-0">Senha</label>
                                    <a href="#" class="text-decoration-none small fw-medium"
                                       style="color: var(--blue-main);">Recuperar senha</a>
                                </div>
                                <input type="password" class="form-control" id="password" value="12345678" required>
                            </div>

                            <button type="submit" class="btn btn-blue w-100 mt-3">Entrar no sistema</button>
                        </form>
                    </div>

                    <div class="text-center mt-4 text-secondary" style="font-size: 0.8rem;">
                        EduCore System v2.0 &mdash; Acesso restrito
                    </div>
                </div>
            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>
