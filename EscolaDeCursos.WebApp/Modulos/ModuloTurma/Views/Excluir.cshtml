@model EscolaDeCursos.WebApp.Modulos.ModuloTurma.ExcluirTurmaViewModel

@{
    Layout = "_Layout";
    ViewBag.Title = "Excluir Turma";
}

<div class="container mt-4">
    <div class="card border-danger shadow-sm col-md-6 mx-auto">
        <div class="card-header bg-danger text-white p-3">
            <h4 class="mb-0">@ViewBag.Title</h4>
        </div>
        <div class="card-body p-4">
            <div class="alert alert-warning">
                <h5 class="mb-1"><i class="bi bi-exclamation-triangle"></i> Atenção</h5>
                Tem certeza que deseja excluir esta turma definitivamente?
            </div>

            <dl class="row mt-3 mb-0">
                <dt class="col-sm-4">Curso:</dt>
                <dd class="col-sm-8">@Model.Curso</dd>

                <dt class="col-sm-4">Instrutor:</dt>
                <dd class="col-sm-8">@Model.Instrutor</dd>

                <dt class="col-sm-4">Período:</dt>
                <dd class="col-sm-8">@Model.DataInicio.ToShortDateString() até @Model.DataTermino.ToShortDateString()</dd>

                <dt class="col-sm-4">Alunos Máx:</dt>
                <dd class="col-sm-8">@Model.NumeroMaximoAlunos</dd>
            </dl>

            <form asp-action="Excluir" method="post" class="mt-4 d-flex gap-2">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4">Confirmar Exclusão</button>
                <a asp-action="Listar" class="btn btn-secondary px-4">Cancelar</a>
            </form>
        </div>
    </div>
</div>
