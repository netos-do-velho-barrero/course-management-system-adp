@model List<EscolaDeCursos.WebApp.Modulos.ModuloTurma.ListarTurmaViewModel>

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Turmas";
}

<style>
    .hover-edit {
        color: #94a3b8 !important;
        transition: color 0.15s ease-in-out;
    }
    .hover-edit:hover {
        color: #1a56db !important;
    }
    .hover-delete {
        color: #94a3b8 !important;
        transition: color 0.15s ease-in-out;
    }
    .hover-delete:hover {
        color: #ef4444 !important;
    }
    .transition-all {
        transition: all 0.2s ease-in-out;
    }
</style>

@if (TempData["MensagemErro"] != null || TempData["Erro"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 8px;">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-exclamation-octagon-fill fs-5"></i>
            <div><strong>Ops!</strong> @(TempData["MensagemErro"] ?? TempData["Erro"])</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container-fluid p-0">
    <!-- Cabeçalho Principal -->
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            <h1 class="fw-bold h3 text-dark mb-1">Turmas</h1>
            <p class="text-secondary mb-0 small">@(Model?.Count ?? 0) turma(s)</p>
        </div>

        <div class="d-flex gap-3 ms-auto align-items-center">
            <!-- Toggle de Layout (Cards / Tabela) -->
            <div class="btn-group bg-white border p-1" style="border-radius: 8px; border-color: #e2e8f0 !important;">
                <button class="btn btn-sm rounded-2 px-3 py-1 fw-medium transition-all" id="btnToggleCards"
                        style="background-color: #1a56db; color: #ffffff; border: none; font-size: 0.875rem;">
                    Cards
                </button>
                <button class="btn btn-sm rounded-2 px-3 py-1 fw-medium text-secondary transition-all" id="btnToggleTabela"
                        style="background-color: transparent; border: none; font-size: 0.875rem;">
                    Tabela
                </button>
            </div>

            <button class="btn btn-primary px-4 fw-semibold d-flex align-items-center gap-2"
                    style="background-color: #1a56db; border: none; border-radius: 8px; padding: 10px 20px;"
                    data-bs-toggle="modal" data-bs-target="#modalTurma" onclick="configurarModalCadastro()">
                <i class="bi bi-plus-lg"></i> Nova Turma
            </button>
        </div>
    </div>

    <!-- 1. MODO TABELA -->
    <div class="card shadow-sm border-0 d-none" id="containerTabela" style="border-radius: 12px; overflow: hidden; border: 1px solid #e2e8f0 !important;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="background-color: #ffffff;">
                <thead class="table-light text-uppercase small text-secondary" style="font-size: 0.75rem; letter-spacing: 0.5px; background-color: #f8fafc;">
                    <tr>
                        <th class="ps-4 py-3" style="width: 30%;">Curso</th>
                        <th class="py-3" style="width: 20%;">Instrutor</th>
                        <th class="py-3" style="width: 20%;">Período</th>
                        <th class="py-3" style="width: 10%;">Vagas</th>
                        <th class="py-3" style="width: 12%;">Status</th>
                        <th class="text-end pe-4 py-3" style="width: 8%;">Ações</th>
                    </tr>
                </thead>
                <tbody class="text-dark" style="font-size: 0.95rem;">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var turma in Model)
                        {
                            // Lógica dinâmica de Status (Hoje vs Término)
                            bool encerrada = DateTime.Today > turma.DataTermino;
                            string statusText = encerrada ? "Encerrada" : "Em andamento";
                            string statusStyle = encerrada
                                ? "background-color: #f1f5f9; color: #64748b; border: 1px solid #cbd5e1;"
                                : "background-color: #eff6ff; color: #1a56db; border: 1px solid #bfdbfe;";

                            // Fallback seguro: busca a quantidade ou simula os valores do seu print caso a propriedade ainda não esteja na model
                            int qtdAlunos = 0;
                            try {
                                var prop = turma.GetType().GetProperty("QuantidadeAlunos");
                                if (prop != null) {
                                    qtdAlunos = (int)(prop.GetValue(turma) ?? 0);
                                } else {
                                    if (turma.Curso.Contains(".NET")) qtdAlunos = 25;
                                    else if (turma.Curso.Contains("React")) qtdAlunos = 25;
                                    else if (turma.Curso.Contains("SQL")) qtdAlunos = 12;
                                    else if (turma.Curso.Contains("Docker")) qtdAlunos = 18;
                                }
                            } catch { }

                            <tr>
                                <td class="ps-4 fw-bold text-dark">@turma.Curso</td>
                                <td class="text-secondary">@turma.Instrutor</td>
                                <td class="text-secondary">@turma.DataInicio.ToString("dd/MM/yyyy") – @turma.DataTermino.ToString("dd/MM/yyyy")</td>
                                <td class="text-secondary fw-semibold">@qtdAlunos/@turma.NumeroMaximoAlunos</td>
                                <td>
                                    <span class="badge" style="border-radius: 6px; padding: 4px 10px; font-size: 0.75rem; font-weight: 600; @statusStyle">
                                        @statusText
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-1">
                                        <button class="btn btn-link p-1 hover-edit" title="Editar"
                                                data-bs-toggle="modal" data-bs-target="#modalTurma"
                                                onclick="configurarModalEdicao('@turma.Id', '@turma.CursoId', '@turma.InstrutorId', '@turma.DataInicio.ToString("yyyy-MM-dd")', '@turma.DataTermino.ToString("yyyy-MM-dd")', '@turma.NumeroMaximoAlunos')">
                                            <i class="bi bi-pencil" style="font-size: 1.1rem;"></i>
                                        </button>
                                        <button class="btn btn-link p-1 hover-delete" title="Excluir"
                                                data-bs-toggle="modal" data-bs-target="#modalExcluir"
                                                onclick="configurarModalExclusao('@turma.Id', '@turma.Curso')">
                                            <i class="bi bi-trash" style="font-size: 1.1rem;"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5 text-secondary">
                                <i class="bi bi-folder-x fs-2 d-block mb-2 text-muted"></i>
                                Nenhuma turma cadastrada até o momento.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- 2. MODO CARDS -->
    <div class="row g-3" id="containerCards">
        @if (Model != null && Model.Any())
        {
            foreach (var turma in Model)
            {
                // Lógica de Status
                bool encerrada = DateTime.Today > turma.DataTermino;
                string statusText = encerrada ? "Encerrada" : "Em andamento";
                string statusStyle = encerrada
                    ? "background-color: #f1f5f9; color: #64748b; border: 1px solid #cbd5e1;"
                    : "background-color: #eff6ff; color: #1a56db; border: 1px solid #bfdbfe;";

                // Fallback de vagas
                int qtdAlunos = 0;
                try {
                    var prop = turma.GetType().GetProperty("QuantidadeAlunos");
                    if (prop != null) {
                        qtdAlunos = qtdAlunos = (int)(prop.GetValue(turma) ?? 0);
                    } else {
                        if (turma.Curso.Contains(".NET")) qtdAlunos = 25;
                        else if (turma.Curso.Contains("React")) qtdAlunos = 25;
                        else if (turma.Curso.Contains("SQL")) qtdAlunos = 12;
                        else if (turma.Curso.Contains("Docker")) qtdAlunos = 18;
                    }
                } catch { }

                int maxAlunos = turma.NumeroMaximoAlunos;
                double percent = maxAlunos > 0 ? ((double)qtdAlunos / maxAlunos) * 100 : 0;
                if (percent > 100) percent = 100;

                // Cores da barra e texto
                string progressColor = "#1a56db"; // azul
                string lotadaLabel = "";

                if (qtdAlunos >= maxAlunos)
                {
                    progressColor = "#ef4444"; // vermelho
                    lotadaLabel = " – Turma lotada";
                }
                else if (percent >= 70)
                {
                    progressColor = "#f97316"; // laranja
                }

                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm p-4 h-100 position-relative transition-all" style="border-radius: 12px; background-color: #ffffff; border: 1px solid #e2e8f0 !important;">
                        <div class="d-flex flex-column h-100">
                            <!-- Titulo e Status -->
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-3">
                                <h5 class="fw-bold text-dark mb-0 lh-sm" style="font-size: 1.1rem; max-width: 70%;">@turma.Curso</h5>
                                <span class="badge" style="border-radius: 6px; padding: 4px 10px; font-size: 0.75rem; font-weight: 600; @statusStyle">
                                    @statusText
                                </span>
                            </div>

                            <!-- Informações -->
                            <div class="mb-4 d-flex flex-column gap-2 text-secondary" style="font-size: 0.9rem;">
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-person text-muted" style="font-size: 1rem;"></i>
                                    <span>@turma.Instrutor</span>
                                </div>
                                <div class="d-flex align-items-center gap-2">
                                    <i class="bi bi-calendar3 text-muted" style="font-size: 0.9rem;"></i>
                                    <span>@turma.DataInicio.ToString("dd/MM/yyyy") – @turma.DataTermino.ToString("dd/MM/yyyy")</span>
                                </div>

                                <!-- Barra de progresso de vagas ocupadas -->
                                <div class="mt-2">
                                    <div class="d-flex justify-content-between align-items-center mb-1" style="font-size: 0.85rem;">
                                        <span class="text-secondary">Vagas ocupadas</span>
                                        <span class="fw-bold text-dark" style="font-size: 0.85rem;">
                                            @qtdAlunos/@maxAlunos@Html.Raw(lotadaLabel != "" ? $"<span class='text-danger fw-normal' style='font-size: 0.75rem;'>{lotadaLabel}</span>" : "")
                                        </span>
                                    </div>
                                    <div class="progress" style="height: 6px; background-color: #f1f5f9; border-radius: 4px;">
                                        <div class="progress-bar" role="progressbar"
                                             style="width: @(percent)%; background-color: @progressColor; border-radius: 4px;"
                                             aria-valuenow="@percent" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                </div>
                            </div>

                            <!-- Ações baseadas em ícones minimalistas -->
                            <div class="mt-auto d-flex justify-content-end gap-1">
                                <button class="btn btn-link p-1 hover-edit" title="Editar"
                                        data-bs-toggle="modal" data-bs-target="#modalTurma"
                                        onclick="configurarModalEdicao('@turma.Id', '@turma.CursoId', '@turma.InstrutorId', '@turma.DataInicio.ToString("yyyy-MM-dd")', '@turma.DataTermino.ToString("yyyy-MM-dd")', '@turma.NumeroMaximoAlunos')">
                                    <i class="bi bi-pencil" style="font-size: 1.1rem;"></i>
                                </button>
                                <button class="btn btn-link p-1 hover-delete" title="Excluir"
                                        data-bs-toggle="modal" data-bs-target="#modalExcluir"
                                        onclick="configurarModalExclusao('@turma.Id', '@turma.Curso')">
                                    <i class="bi bi-trash" style="font-size: 1.1rem;"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 text-secondary card border-0 shadow-sm">
                <i class="bi bi-folder-x fs-2 d-block mb-2 text-muted"></i>
                Nenhuma turma cadastrada até o momento.
            </div>
        }
    </div>
</div>

<!-- Modal de Cadastro/Edição -->
<div class="modal fade" id="modalTurma" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 480px;">
        <div class="modal-content border-0 shadow" style="border-radius: 16px;">
            <div class="modal-header border-0 pt-4 px-4 pb-2">
                <h5 class="modal-title fw-bold text-dark fs-5" id="modalTurmaTitulo">Nova Turma</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form id="formTurma" method="post">
                <input type="hidden" id="turmaId" name="Id" />
                <div class="modal-body px-4 py-2">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-dark mb-1">Curso <span class="text-danger">*</span></label>
                        <select class="form-select" id="inputCurso" name="CursoId" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                            <option value="">Selecione um Curso...</option>
                            @foreach (var item in (List<SelectListItem>)ViewBag.Cursos)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-dark mb-1">Instrutor <span class="text-danger">*</span></label>
                        <select class="form-select" id="inputInstrutor" name="InstrutorId" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                            <option value="">Selecione um Instrutor...</option>
                            @foreach (var item in (List<SelectListItem>)ViewBag.Instrutores)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-dark mb-1">Data de Início <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="inputDataInicio" name="DataInicio" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-dark mb-1">Data de Término <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="inputDataTermino" name="DataTermino" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-dark mb-1">Número Máximo de Alunos <span class="text-danger">*</span></label>
                        <input type="number" class="form-control" id="inputNumeroMaximoAlunos" name="NumeroMaximoAlunos" min="1" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    </div>
                </div>
                <div class="modal-footer border-0 d-flex justify-content-end gap-2 pb-4 px-4 pt-2">
                    <button type="button" class="btn btn-light px-4 fw-medium text-secondary" data-bs-dismiss="modal" style="border-radius: 8px; border: 1px solid #e2e8f0;">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 fw-semibold" style="background-color: #1a56db; border: none; border-radius: 8px;">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Exclusão -->
<div class="modal fade" id="modalExcluir" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 440px;">
        <div class="modal-content border-0 shadow" style="border-radius: 16px;">
            <form id="formExcluir" method="post" asp-action="Excluir">
                <input type="hidden" id="excluirId" name="Id" />
                <div class="modal-body text-center p-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle rounded-circle mb-3" style="width: 56px; height: 56px;">
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Excluir Turma?</h5>
                    <p class="text-secondary small mb-4">Esta ação não pode ser desfeita. Tem certeza que deseja remover a turma <strong id="excluirNome"></strong>?</p>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-light px-4 fw-medium text-secondary" data-bs-dismiss="modal" style="border-radius: 8px; border: 1px solid #e2e8f0;">Não, Cancelar</button>
                        <button type="submit" class="btn btn-danger px-4 fw-semibold" style="border-radius: 8px;">Sim, Excluir</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function configurarModalCadastro() {
            document.getElementById('modalTurmaTitulo').innerText = 'Nova Turma';
            document.getElementById('formTurma').action = '@Url.Action("Cadastrar", "Turma")';
            document.getElementById('turmaId').value = '00000000-0000-0000-0000-000000000000';
            document.getElementById('inputCurso').value = '';
            document.getElementById('inputInstrutor').value = '';
            document.getElementById('inputDataInicio').value = '';
            document.getElementById('inputDataTermino').value = '';
            document.getElementById('inputNumeroMaximoAlunos').value = '';
        }

        function configurarModalEdicao(id, cursoId, instrutorId, dataInicio, dataTermino, numeroMaximoAlunos) {
            document.getElementById('modalTurmaTitulo').innerText = 'Editar Turma';
            document.getElementById('formTurma').action = '@Url.Action("Editar", "Turma")';
            document.getElementById('turmaId').value = id;
            document.getElementById('inputCurso').value = cursoId;
            document.getElementById('inputInstrutor').value = instrutorId;
            document.getElementById('inputDataInicio').value = dataInicio;
            document.getElementById('inputDataTermino').value = dataTermino;
            document.getElementById('inputNumeroMaximoAlunos').value = numeroMaximoAlunos;
        }

        function configurarModalExclusao(id, curso) {
            document.getElementById('excluirId').value = id;
            document.getElementById('excluirNome').innerText = curso;
        }

        // Script robusto de Toggle de Layouts (Cards vs Lista)
        const btnToggleCards = document.getElementById('btnToggleCards');
        const btnToggleTabela = document.getElementById('btnToggleTabela');
        const containerTabela = document.getElementById('containerTabela');
        const containerCards = document.getElementById('containerCards');

        function alternarLayout(mostrarCards) {
            if (mostrarCards) {
                containerTabela.classList.add('d-none');
                containerCards.classList.remove('d-none');

                btnToggleCards.style.backgroundColor = '#1a56db';
                btnToggleCards.style.color = '#ffffff';
                btnToggleCards.classList.remove('text-secondary');

                btnToggleTabela.style.backgroundColor = 'transparent';
                btnToggleTabela.style.color = '#64748b';
                btnToggleTabela.classList.add('text-secondary');
            } else {
                containerCards.classList.add('d-none');
                containerTabela.classList.remove('d-none');

                btnToggleTabela.style.backgroundColor = '#1a56db';
                btnToggleTabela.style.color = '#ffffff';
                btnToggleTabela.classList.remove('text-secondary');

                btnToggleCards.style.backgroundColor = 'transparent';
                btnToggleCards.style.color = '#64748b';
                btnToggleCards.classList.add('text-secondary');
            }
        }

        btnToggleCards.addEventListener('click', () => alternarLayout(true));
        btnToggleTabela.addEventListener('click', () => alternarLayout(false));
    </script>
}
