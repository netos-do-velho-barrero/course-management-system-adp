@model IEnumerable<EscolaDeCursos.WebApp.Modulos.ModuloTurma.ListarTurmaViewModel>

@{
    Layout = "_Layout";
    ViewBag.Title = "Listagem de Turmas";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>@ViewBag.Title</h2>
        <a asp-action="Cadastrar" class="btn btn-primary">Nova Turma</a>
    </div>

    <div class="row">
        @foreach (var turma in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm border-0">
                    <div class="card-body">
                        <h5 class="card-title text-primary fw-bold">@turma.Curso</h5>
                        <hr />
                        <p class="card-text mb-2"><strong>Instrutor:</strong> @turma.Instrutor</p>
                        <p class="card-text mb-2"><strong>Início:</strong> @turma.DataInicio.ToShortDateString()</p>
                        <p class="card-text mb-2"><strong>Término:</strong> @turma.DataTermino.ToShortDateString()</p>
                        <p class="card-text mb-0"><strong>Máx. Alunos:</strong> @turma.NumeroMaximoAlunos</p>
                    </div>
                    <div class="card-footer bg-transparent border-top-0 d-flex justify-content-end gap-2 pb-3">
                        <a asp-action="Editar" asp-route-id="@turma.Id" class="btn btn-sm btn-warning">Editar</a>
                        <a asp-action="Excluir" asp-route-id="@turma.Id" class="btn btn-sm btn-danger">Excluir</a>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">Nenhuma turma cadastrada no momento.</div>
    }
</div>
