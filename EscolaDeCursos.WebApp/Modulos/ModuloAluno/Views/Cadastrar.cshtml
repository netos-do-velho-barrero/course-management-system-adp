@using EscolaDeCursos.WebApp.Modulos.ModuloAluno
@model CadastrarAlunoViewModel

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Aluno";
}

<div class="container-fluid p-0">
    <div class="mb-4">
        <h1 class="fw-bold h3 text-dark mb-1">Novo Aluno</h1>
        <p class="text-secondary mb-0 small">Cadastre um novo aluno no sistema</p>
    </div>

    <div class="card border-0 shadow-sm mx-auto" style="max-width: 620px; border-radius: 16px;">
        <div class="card-body p-4">
            <form asp-action="Cadastrar" method="post">
                <div class="mb-3">
                    <label asp-for="Nome" class="form-label small fw-semibold text-dark mb-1">Nome Completo</label>
                    <input asp-for="Nome" type="text" class="form-control" placeholder="Ex: João Silva" style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    <span asp-validation-for="Nome" class="text-danger small fw-semibold"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Cpf" class="form-label small fw-semibold text-dark mb-1">CPF</label>
                    <input asp-for="Cpf" type="text" class="form-control" placeholder="000.000.000-00" style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    <span asp-validation-for="Cpf" class="text-danger small fw-semibold"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Telefone" class="form-label small fw-semibold text-dark mb-1">Telefone</label>
                    <input asp-for="Telefone" type="text" class="form-control" placeholder="(48) 99999-9999" style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    <span asp-validation-for="Telefone" class="text-danger small fw-semibold"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label small fw-semibold text-dark mb-1">E-mail</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="nome@email.com" style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    <span asp-validation-for="Email" class="text-danger small fw-semibold"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-2">
                    <a class="btn btn-light px-4 fw-medium text-secondary" asp-action="Listar" style="border-radius: 8px; border: 1px solid #e2e8f0;">Voltar</a>
                    <button class="btn btn-primary px-4 fw-semibold" type="submit" style="background-color: #1a56db; border: none; border-radius: 8px;">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>
