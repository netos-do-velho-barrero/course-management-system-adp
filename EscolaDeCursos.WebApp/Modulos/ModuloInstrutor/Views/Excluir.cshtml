@model EscolaDeCursos.WebApp.Modulos.ModuloInstrutor.ExcluirInstrutorViewModel

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Instrutor";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 mx-auto p-4"
         style="max-width: 620px; border-radius: 12px; background-color: #ffffff;">

        <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle rounded-circle mb-3 mx-auto" style="width: 56px; height: 56px;">
            <i class="bi bi-exclamation-triangle-fill text-danger fs-3"></i>
        </div>

        <h5 class="fw-bold text-dark mb-2 text-center">Excluir Instrutor?</h5>
        <p class="text-secondary small mb-4 text-center">Esta ação não pode ser desfeita.</p>

        <dl class="row mb-0">
            <dt class="col-sm-4 fw-semibold text-dark text-uppercase small">ID</dt>
            <dd class="col-sm-8 text-break">@Model.Id</dd>

            <dt class="col-sm-4 fw-semibold text-dark text-uppercase small">Nome</dt>
            <dd class="col-sm-8">@Model.Nome</dd>

            <dt class="col-sm-4 fw-semibold text-dark text-uppercase small">Telefone</dt>
            <dd class="col-sm-8">@Model.Telefone</dd>

            <dt class="col-sm-4 fw-semibold text-dark text-uppercase small">E-mail</dt>
            <dd class="col-sm-8 text-break">@Model.Email</dd>
        </dl>

        <form asp-action="Excluir" asp-route-id="@Model.Id" method="post">
            <input asp-for="Id" type="hidden">
            <div class="d-flex justify-content-end gap-2 mt-4">
                <a class="btn btn-light px-4 fw-medium text-secondary"
                   style="border-radius: 8px; border: 1px solid #e2e8f0;" asp-action="Listar">Voltar</a>
                <button class="btn btn-danger px-4 fw-semibold" style="border-radius: 8px;" type="submit">Confirmar</button>
            </div>
        </form>
    </div>
</div>
