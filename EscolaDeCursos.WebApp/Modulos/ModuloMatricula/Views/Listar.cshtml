@using EscolaDeCursos.Dominio.Modulos.ModuloMatricula
@using EscolaDeCursos.WebApp.Modulos.ModuloMatricula
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Matrículas";
}

@model List<ListarMatriculaViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Nova Matrícula</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma matrícula cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListarMatriculaViewModel m in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">Matrícula</h5>
                            <span class="badge text-bg-primary rounded-pill">@m.Id.ToString().Substring(0, 8)</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Aluno</dt>
                            <dd class="col-7 mb-0 text-break">@m.AlunoId.ToString().Substring(0, 8)</dd>

                            <dt class="col-5 text-secondary fw-semibold">Turma</dt>
                            <dd class="col-7 mb-0 text-break">@m.TurmaId.ToString().Substring(0, 8)</dd>

                            <dt class="col-5 text-secondary fw-semibold">Data</dt>
                            <dd class="col-7 mb-0">@m.DataMatricula.ToString("dd/MM/yyyy")</dd>

                            <dt class="col-5 text-secondary fw-semibold">Situação</dt>
                            <dd class="col-7 mb-0">
                                <span class="badge rounded-pill @(m.Situacao == SituacaoMatricula.Ativa ? "text-bg-success" : m.Situacao == SituacaoMatricula.Cancelada ? "text-bg-danger" : "text-bg-secondary")">
                                    @m.Situacao
                                </span>
                            </dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar" asp-route-id="@m.Id">Editar</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir" asp-route-id="@m.Id">Excluir</a>

                            @if (m.Situacao == SituacaoMatricula.Ativa)
                            {
                                <form asp-action="Concluir" asp-route-id="@m.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-success btn-sm rounded-pill px-3">Concluir</button>
                                </form>
                                <form asp-action="Cancelar" asp-route-id="@m.Id" method="post" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Cancelar</button>
                                </form>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
