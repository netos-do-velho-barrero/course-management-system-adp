@using EscolaDeCursos.WebApp.Modulos.ModuloMatricula
@using EscolaDeCursos.Dominio.Modulos.ModuloMatricula
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Matrícula";
}

@model EditarMatriculaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Editar" asp-route-id="@Model.Id" method="post">
    <input asp-for="Id" type="hidden">

    <div class="mb-3">
        <label asp-for="Situacao" class="form-label fw-semibold text-primary text-uppercase small">Situação</label>
        <select asp-for="Situacao" class="form-select" asp-items="Html.GetEnumSelectList<SituacaoMatricula>()"></select>
        <span asp-validation-for="Situacao" class="text-danger small fw-semibold"></span>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
        <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
    </div>
    <div class="mb-3">
    <label class="form-label fw-semibold text-primary text-uppercase small">Data da Matrícula</label>
    <input type="text" class="form-control" value="@DateTime.Today.ToString("dd/MM/yyyy")" readonly disabled>
</div>

<div class="mb-3">
    <label class="form-label fw-semibold text-primary text-uppercase small">Situação</label>
    <input type="text" class="form-control" value="Ativa" readonly disabled>
</div>
</form>
