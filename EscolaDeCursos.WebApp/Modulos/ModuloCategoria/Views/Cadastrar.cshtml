@model EscolaDeCursos.WebApp.Modulos.ModuloCategoria.CadastrarCategoriaViewModel

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Categoria";
}

<div class="container py-4">
    <div class="card shadow-sm border-0 mx-auto p-4"
         style="max-width: 620px; border-radius: 12px; background-color: #ffffff;">
        <h4 class="fw-bold text-dark mb-4">Nova Categoria</h4>

        <form asp-action="Cadastrar" method="post">
            <div class="mb-3">
                <label asp-for="Nome" class="form-label fw-semibold text-dark small text-uppercase">Nome da
                    Categoria</label>
                    <input asp-for="Nome" type="text" class="form-control"
                           style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;"
                           placeholder="Ex: Desenvolvimento Web">
                    <span asp-validation-for="Nome" class="text-danger small fw-semibold mt-1 d-block"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4">
                    <a class="btn btn-light px-4 fw-medium text-secondary"
                       style="border-radius: 8px; border: 1px solid #e2e8f0;" asp-action="Listar">Voltar</a>
                    <button class="btn btn-primary px-4 fw-semibold"
                            style="background-color: #1a56db; border: none; border-radius: 8px;"
                            type="submit">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
