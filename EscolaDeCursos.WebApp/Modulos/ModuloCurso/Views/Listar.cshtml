@using EscolaDeCursos.WebApp.Modulos.ModuloCurso
@using EscolaDeCursos.Dominio.Modulos.ModuloCurso
@using Microsoft.AspNetCore.Mvc.Rendering
@model List<ListarCursosViewModel>

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Cursos";
}

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" role="alert" style="border-radius: 8px;">
        <div class="d-flex align-items-center gap-2">
            <i class="bi bi-exclamation-octagon-fill fs-5"></i>
            <div><strong>Ops!</strong> @mensagemErro</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="container-fluid p-0">
    <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3 mb-4">
        <div>
            <h1 class="fw-bold h3 text-dark mb-1">Cursos</h1>
            <p class="text-secondary mb-0 small">Listagem de cursos do sistema</p>
        </div>

        <div class="d-flex gap-2 ms-auto">
            <button class="btn btn-light border d-flex align-items-center gap-2 fw-semibold px-3"
                    id="btnAlternarLayout" style="border-radius: 8px;">
                <i class="bi bi-grid" id="layoutIcon"></i>
                <span class="d-none d-md-inline" id="layoutText">Ver em Cards</span>
            </button>

            <button class="btn btn-primary px-4 fw-semibold d-flex align-items-center gap-2"
                    style="background-color: #1a56db; border: none; border-radius: 8px; padding: 10px 20px;"
                    data-bs-toggle="modal" data-bs-target="#modalCurso" onclick="configurarModalCadastro()">
                <i class="bi bi-plus-lg"></i> Novo Curso
            </button>
        </div>
    </div>

    <!-- 1. MODO TABELA -->
    <div class="card shadow-sm border-0 d-md-block" id="containerTabela" style="border-radius: 12px; overflow: hidden;">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="background-color: #ffffff;">
                <thead class="table-light text-uppercase small text-secondary" style="font-size: 0.75rem; letter-spacing: 0.5px; background-color: #f8fafc;">
                    <tr>
                        <th class="ps-4 py-3">Nome</th>
                        <th class="py-3">Nível</th>
                        <th class="py-3">Carga Horária</th>
                        <th class="py-3">Descrição</th>
                        <th class="text-end pe-4 py-3" style="width: 240px;">Ações</th>
                    </tr>
                </thead>
                <tbody class="text-dark" style="font-size: 0.95rem;">
                    @if (Model != null && Model.Any())
                    {
                        foreach (ListarCursosViewModel c in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">@c.Nome</td>
                                <td>
                                    <span class="badge text-bg-light border px-2 py-1" style="font-size: 0.8rem; border-radius: 6px;">
                                        @c.Nivel
                                    </span>
                                </td>
                                <td>@c.CargaHoraria horas</td>
                                <td class="text-truncate" style="max-width: 200px;" title="@c.Descricao">
                                    @c.Descricao
                                </td>
                                <td class="text-end pe-4">
                                    <div class="d-flex justify-content-end gap-2">
                                        <button class="btn btn-sm px-3 py-2 d-inline-flex align-items-center gap-2 fw-medium"
                                                style="background-color: #eff6ff; color: #1a56db; border: 1px solid #bfdbfe; border-radius: 8px;"
                                                data-bs-toggle="modal" data-bs-target="#modalCurso"
                                                onclick="configurarModalEdicao('@c.Id', '@Html.Raw(c.Nome)', '@c.CategoriaId', '@Html.Raw((int)c.Nivel)', '@c.CargaHoraria', '@Html.Raw(c.Descricao)')">
                                            <i class="bi bi-pencil-square"></i> Editar
                                        </button>
                                        <button class="btn btn-sm px-3 py-2 d-inline-flex align-items-center gap-2 fw-medium"
                                                style="background-color: #fef2f2; color: #dc3545; border: 1px solid #fecaca; border-radius: 8px;"
                                                data-bs-toggle="modal" data-bs-target="#modalExcluir"
                                                onclick="configurarModalExclusao('@c.Id', '@Html.Raw(c.Nome)')">
                                            <i class="bi bi-trash3"></i> Excluir
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-secondary">
                                <i class="bi bi-folder-x fs-2 d-block mb-2 text-muted"></i>
                                Nenhum curso cadastrado até o momento.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- 2. MODO CARDS -->
    <div class="row g-3 d-none" id="containerCards">
        @if (Model != null && Model.Any())
        {
            foreach (ListarCursosViewModel c in Model)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="card border-0 shadow-sm p-4 h-100" style="border-radius: 12px; background-color: #ffffff;">
                        <div class="d-flex flex-column h-100">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                                <h5 class="fw-bold text-dark mb-0">@c.Nome</h5>
                                <span class="badge text-bg-primary rounded-pill px-2 py-1 small" style="background-color: #1a56db !important; font-size: 0.75rem;">
                                    @c.Nivel
                                </span>
                            </div>

                            <p class="text-secondary small mb-4 flex-grow-1">@c.Descricao</p>

                            <dl class="row g-2 mb-4" style="font-size: 0.9rem;">
                                <dt class="col-5 text-secondary fw-semibold">Carga Horária</dt>
                                <dd class="col-7 mb-0 text-dark">@c.CargaHoraria horas</dd>
                            </dl>

                            <div class="mt-auto d-flex gap-2">
                                <button class="btn btn-sm px-3 py-2 d-inline-flex align-items-center justify-content-center gap-2 fw-medium w-50"
                                        style="background-color: #eff6ff; color: #1a56db; border: 1px solid #bfdbfe; border-radius: 8px;"
                                        data-bs-toggle="modal" data-bs-target="#modalCurso"
                                        onclick="configurarModalEdicao('@c.Id', '@Html.Raw(c.Nome)', '@c.CategoriaId', '@Html.Raw((int)c.Nivel)', '@c.CargaHoraria', '@Html.Raw(c.Descricao)')">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </button>
                                <button class="btn btn-sm px-3 py-2 d-inline-flex align-items-center justify-content-center gap-2 fw-medium w-50"
                                        style="background-color: #fef2f2; color: #dc3545; border: 1px solid #fecaca; border-radius: 8px;"
                                        data-bs-toggle="modal" data-bs-target="#modalExcluir"
                                        onclick="configurarModalExclusao('@c.Id', '@Html.Raw(c.Nome)')">
                                    <i class="bi bi-trash3"></i> Excluir
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5 text-secondary card border-0 shadow-sm">
                <i class="bi bi-folder-x fs-2 d-block mb-2 text-muted"></i>
                Nenhum curso cadastrado.
            </div>
        }
    </div>
</div>

<!-- Modal de Cadastro/Edição -->
<div class="modal fade" id="modalCurso" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
        <div class="modal-content border-0 shadow" style="border-radius: 16px;">
            <div class="modal-header border-0 pt-4 px-4 pb-2">
                <h5 class="modal-title fw-bold text-dark fs-5" id="modalCursoTitulo">Novo Curso</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form id="formCurso" method="post">
                <input type="hidden" id="cursoId" name="Id" />
                <div class="modal-body px-4 py-2">
                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-dark mb-1">Nome do Curso <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="inputNome" name="Nome" placeholder="Ex: Desenvolvedor C# Completo" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-dark mb-1">Categoria <span class="text-danger">*</span></label>
                        <select class="form-select" id="inputCategoria" name="CategoriaId" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                            <option value="">Selecione uma Categoria...</option>
                            @foreach (var item in (List<SelectListItem>)ViewBag.Categorias)
                            {
                                <option value="@item.Value">@item.Text</option>
                            }
                        </select>
                    </div>

                    <div class="row g-2">
                        <div class="col-6 mb-3">
                            <label class="form-label small fw-semibold text-dark mb-1">Nível <span class="text-danger">*</span></label>
                            <select class="form-select" id="inputNivel" name="Nivel" asp-items="Html.GetEnumSelectList<NivelCurso>()" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                                <option value="">Selecione o Nível...</option>
                            </select>
                        </div>

                        <div class="col-6 mb-3">
                            <label class="form-label small fw-semibold text-dark mb-1">Carga Horária <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="inputCargaHoraria" name="CargaHoraria" placeholder="Ex: 40" min="1" required style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label small fw-semibold text-dark mb-1">Descrição</label>
                        <textarea class="form-control" id="inputDescricao" name="Descricao" rows="3" placeholder="Breve descrição sobre o curso..." style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;"></textarea>
                    </div>
                </div>
                <div class="modal-footer border-0 d-flex justify-content-end gap-2 pb-4 px-4 pt-2">
                    <button type="button" class="btn btn-light px-4 fw-medium text-secondary" data-bs-dismiss="modal" style="border-radius: 8px; border: 1px solid #e2e8f0;">Cancelar</button>
                    <button type="submit" class="btn btn-primary px-4 fw-semibold" style="background-color: #1a56db; border: none; border-radius: 8px;">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Exclusão -->
<div class="modal fade" id="modalExcluir" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" style="max-width: 440px;">
        <div class="modal-content border-0 shadow" style="border-radius: 16px;">
            <form id="formExcluir" method="post" asp-action="Excluir">
                <input type="hidden" id="excluirId" name="Id" />
                <div class="modal-body text-center p-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle rounded-circle mb-3" style="width: 56px; height: 56px;">
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-2">Excluir Curso?</h5>
                    <p class="text-secondary small mb-4">Esta ação não pode ser desfeita. Tem certeza que deseja remover o curso "<strong id="excluirNome"></strong>"?</p>
                    <div class="d-flex justify-content-center gap-2">
                        <button type="button" class="btn btn-light px-4 fw-medium text-secondary" data-bs-dismiss="modal" style="border-radius: 8px; border: 1px solid #e2e8f0;">Não, Cancelar</button>
                        <button type="submit" class="btn btn-danger px-4 fw-semibold" style="border-radius: 8px;">Sim, Excluir</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function configurarModalCadastro() {
            document.getElementById('modalCursoTitulo').innerText = 'Novo Curso';
            document.getElementById('formCurso').action = '@Url.Action("Cadastrar", "Curso")';
            document.getElementById('cursoId').value = '00000000-0000-0000-0000-000000000000';
            document.getElementById('inputNome').value = '';
            document.getElementById('inputCategoria').value = '';
            document.getElementById('inputNivel').value = '';
            document.getElementById('inputCargaHoraria').value = '';
            document.getElementById('inputDescricao').value = '';
        }

        function configurarModalEdicao(id, nome, categoriaId, nivel, cargaHoraria, descricao) {
            document.getElementById('modalCursoTitulo').innerText = 'Editar Curso';
            document.getElementById('formCurso').action = '@Url.Action("Editar", "Curso")';
            document.getElementById('cursoId').value = id;
            document.getElementById('inputNome').value = nome;
            document.getElementById('inputCategoria').value = categoriaId;
            document.getElementById('inputNivel').value = nivel;
            document.getElementById('inputCargaHoraria').value = cargaHoraria;
            document.getElementById('inputDescricao').value = descricao;
        }

        function configurarModalExclusao(id, nome) {
            document.getElementById('excluirId').value = id;
            document.getElementById('excluirNome').innerText = nome;
        }

        const btnAlternar = document.getElementById('btnAlternarLayout');
        const containerTabela = document.getElementById('containerTabela');
        const containerCards = document.getElementById('containerCards');
        const layoutIcon = document.getElementById('layoutIcon');
        const layoutText = document.getElementById('layoutText');

        btnAlternar.addEventListener('click', () => {
            const tabelaVisivel = window.getComputedStyle(containerTabela).display !== 'none';
            containerTabela.classList.remove('d-md-block');
            containerCards.classList.remove('d-md-none');

            if (tabelaVisivel) {
                containerTabela.classList.add('d-none');
                containerCards.classList.remove('d-none');
                layoutIcon.className = "bi bi-list-task";
                layoutText.innerText = "Ver em Lista";
            } else {
                containerCards.classList.add('d-none');
                containerTabela.classList.remove('d-none');
                layoutIcon.className = "bi bi-grid";
                layoutText.innerText = "Ver em Cards";
            }
        });
    </script>
}
