@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Cursos";
}

@model List<ListarCursosViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">
    Cadastrar Novo
</a>

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3">
        Nenhum curso cadastrado.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">

        @foreach (ListarCursosViewModel c in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@c.Nome</h5>
                            <span class="badge text-bg-primary rounded-pill">
                                @c.Nivel
                            </span>
                        </div>

                        <p>@c.Descricao</p>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Carga Horária</dt>
                            <dd class="col-7 mb-0">@c.CargaHoraria horas</dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                               asp-action="Editar"
                               asp-route-id="@c.Id">
                                Editar
                            </a>

                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                               asp-action="Excluir"
                               asp-route-id="@c.Id">
                                Excluir
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }

    </div>
}
