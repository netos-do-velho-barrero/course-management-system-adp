@using EscolaDeCursos.WebApp.Modulos.ModuloAula
@model EditarAulaViewModel

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Aula";
}

<div class="container-fluid p-0">
    <div class="mb-4">
        <h1 class="fw-bold h3 text-dark mb-1">Editar Aula</h1>
        <p class="text-secondary mb-0 small">Atualize as informações da aula cadastrada</p>
    </div>

    <div class="card border-0 shadow-sm mx-auto" style="max-width: 620px; border-radius: 16px;">
        <div class="card-body p-4">
            <form asp-action="Editar" method="post">
                <input asp-for="Id" type="hidden">

                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label small fw-semibold text-dark mb-1">Título</label>
                    <input asp-for="Titulo" type="text" class="form-control" style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                    <span asp-validation-for="Titulo" class="text-danger small fw-semibold"></span>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <label asp-for="Ordem" class="form-label small fw-semibold text-dark mb-1">Ordem</label>
                        <input asp-for="Ordem" type="number" class="form-control" style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                        <span asp-validation-for="Ordem" class="text-danger small fw-semibold"></span>
                    </div>
                    <div class="col-6">
                        <label asp-for="Duracao" class="form-label small fw-semibold text-dark mb-1">Duração (min)</label>
                        <input asp-for="Duracao" type="number" class="form-control" style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                        <span asp-validation-for="Duracao" class="text-danger small fw-semibold"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="CursoId" class="form-label small fw-semibold text-dark mb-1">Curso</label>
                    <select asp-for="CursoId" asp-items="Model.Cursos" class="form-select" style="border-radius: 8px; padding: 10px; border: 1px solid #cbd5e1;">
                        <option value="">Selecione o Curso...</option>
                    </select>
                    <span asp-validation-for="CursoId" class="text-danger small fw-semibold"></span>
                </div>

                <div class="d-flex justify-content-end gap-2 mt-4 pt-2">
                    <a class="btn btn-light px-4 fw-medium text-secondary" asp-action="Listar" style="border-radius: 8px; border: 1px solid #e2e8f0;">Voltar</a>
                    <button class="btn btn-primary px-4 fw-semibold" type="submit" style="background-color: #1a56db; border: none; border-radius: 8px;">Confirmar</button>
                </div>
            </form>
        </div>
    </div>
</div>
