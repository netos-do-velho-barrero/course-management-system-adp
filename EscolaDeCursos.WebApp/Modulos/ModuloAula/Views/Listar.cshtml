@using EscolaDeCursos.WebApp.Modulos.ModuloAula
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Aulas";
}

@model List<ListarAulaViewModel>;

<a class="btn btn-outline-primary rounded-pill px-4 mb-3" asp-action="Cadastrar">Cadastrar Nova Aula</a>

@if (TempData["MensagemErro"] is string mensagemErro)
{
    <div class="alert alert-danger border-start border-danger border-4 rounded-3" role="alert">
        @mensagemErro
    </div>
}

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-start border-primary border-4 rounded-3" role="alert">
        Nenhuma aula cadastrada.
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-2">
        @foreach (ListarAulaViewModel a in Model)
        {
            <div class="col">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start gap-3 mb-3">
                            <h5 class="card-title mb-0">@a.Titulo</h5>
                            <span class="badge text-bg-primary rounded-pill">@a.Id.ToString().Substring(0, 8)</span>
                        </div>

                        <dl class="row g-2 mb-4">
                            <dt class="col-5 text-secondary fw-semibold">Ordem</dt>
                            <dd class="col-7 mb-0 text-break">@a.Ordem</dd>

                            <dt class="col-5 text-secondary fw-semibold">ID do Curso</dt>
                            <dd class="col-7 mb-0 text-break">@a.CursoId.ToString().Substring(0, 8)...</dd>
                        </dl>

                        <div class="d-flex flex-wrap gap-2 mt-auto justify-content-end">
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Editar"
                               asp-route-id="@a.Id">Editar</a>
                            <a class="btn btn-outline-primary btn-sm rounded-pill px-3" asp-action="Excluir"
                               asp-route-id="@a.Id">Excluir</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
