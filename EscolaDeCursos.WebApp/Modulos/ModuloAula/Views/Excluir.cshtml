@using EscolaDeCursos.WebApp.Modulos.ModuloAula
@model ExcluirAulaViewModel

@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Aula";
}

<div class="container-fluid p-0">
    <div class="mb-4">
        <h1 class="fw-bold h3 text-dark mb-1">Excluir Aula</h1>
        <p class="text-secondary mb-0 small">Remover registro de aula do banco de dados</p>
    </div>

    <div class="card border-0 shadow-sm mx-auto" style="max-width: 620px; border-radius: 16px;">
        <div class="card-body p-4">
            <form asp-action="Excluir" asp-route-id="@Model.Id" method="post">
                <input asp-for="Id" type="hidden">

                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger-subtle rounded-circle mb-3" style="width: 56px; height: 56px;">
                        <i class="bi bi-exclamation-triangle-fill text-danger fs-3"></i>
                    </div>
                    <h5 class="fw-bold text-dark mb-1">Tem certeza que deseja excluir?</h5>
                    <p class="text-secondary small mb-0">Esta ação não poderá ser desfeita. Você removerá permanentemente a aula abaixo.</p>
                </div>

                <div class="p-3 bg-light rounded-3 mb-4" style="border: 1px solid #e2e8f0;">
                    <dl class="row mb-0 g-2" style="font-size: 0.95rem;">
                        <dt class="col-sm-4 text-secondary fw-semibold">ID</dt>
                        <dd class="col-sm-8 text-dark text-break mb-1">@Model.Id</dd>

                        <dt class="col-sm-4 text-secondary fw-semibold">Título</dt>
                        <dd class="col-sm-8 text-dark mb-1">@Model.Titulo</dd>

                        <dt class="col-sm-4 text-secondary fw-semibold">Ordem</dt>
                        <dd class="col-sm-8 text-dark mb-1">@Model.Ordem</dd>

                        <dt class="col-sm-4 text-secondary fw-semibold">Duração</dt>
                        <dd class="col-sm-8 text-dark mb-1">@Model.Duracao min</dd>

                        <dt class="col-sm-4 text-secondary fw-semibold">ID do Curso</dt>
                        <dd class="col-sm-8 text-dark text-break mb-0">@Model.CursoId</dd>
                    </dl>
                </div>

                <div class="d-flex justify-content-end gap-2">
                    <a class="btn btn-light px-4 fw-medium text-secondary" asp-action="Listar" style="border-radius: 8px; border: 1px solid #e2e8f0;">Cancelar</a>
                    <button class="btn btn-danger px-4 fw-semibold" type="submit" style="border-radius: 8px;">Sim, Excluir</button>
                </div>
            </form>
        </div>
    </div>
</div>
