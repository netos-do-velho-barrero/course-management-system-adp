@using EscolaDeCursos.WebApp.Modulos.ModuloAula
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Cadastro de Aula";
}

@model CadastrarAulaViewModel;

<form class="card border-primary-subtle shadow-sm mx-auto p-4" style="max-width: 620px;" asp-action="Cadastrar"
      method="post">
    <div class="mb-3">
        <label asp-for="Titulo" class="form-label fw-semibold text-primary text-uppercase small">Título</label>
        <input asp-for="Titulo" type="text" class="form-control" placeholder="Título da Aula">
        <span asp-validation-for="Titulo" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Ordem" class="form-label fw-semibold text-primary text-uppercase small">Ordem</label>
        <input asp-for="Ordem" type="number" class="form-control" placeholder="Ex: 1">
        <span asp-validation-for="Ordem" class="text-danger small fw-semibold"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Duracao" class="form-label fw-semibold text-primary text-uppercase small">Duração
            (minutos)</label>
            <input asp-for="Duracao" type="number" class="form-control" placeholder="Ex: 45">
            <span asp-validation-for="Duracao" class="text-danger small fw-semibold"></span>
        </div>

        <div class="mb-3">
            <label asp-for="CursoId" class="form-label fw-semibold text-primary text-uppercase small">Curso</label>
            <select asp-for="CursoId" asp-items="Model.Cursos" class="form-select">
                <option value="">Selecione o Curso...</option>
            </select>
            <span asp-validation-for="CursoId" class="text-danger small fw-semibold"></span>
        </div>

        <div class="d-flex justify-content-end gap-2 mt-4">
            <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">Voltar</a>
            <button class="btn btn-primary rounded-pill px-4" type="submit">Confirmar</button>
        </div>
    </form>
